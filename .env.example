# API サーバーのベース URL
EXPO_PUBLIC_API_BASE_URL=https://QL-api.adcsvmc.net

# Google OAuth クライアント ID
# Google Cloud Console > 認証情報 から取得してください
# https://console.cloud.google.com/

# iOS クライアント ID（iOSアプリ用）
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=REPLACE_WITH_IOS_CLIENT_ID.apps.googleusercontent.com

# Android クライアント ID（Androidアプリ用）
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=REPLACE_WITH_ANDROID_CLIENT_ID.apps.googleusercontent.com

# Web クライアント ID（サーバーサイド検証用）
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=REPLACE_WITH_WEB_CLIENT_ID.apps.googleusercontent.com

# テストログイン用 Basic 認証ヘッダー（開発環境専用）
# "Basic <base64(user:pass)>" 形式で設定する
# 未設定の場合は空文字列となり、テストログインが 401 エラーになる
EXPO_PUBLIC_TEST_BASIC_AUTH=Basic REPLACE_WITH_BASE64_CREDENTIALS
